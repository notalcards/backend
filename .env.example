APP_NAME=NatalCharts
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# При запуске через Docker используй эти значения:
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=natalcharts
DB_USERNAME=root
DB_PASSWORD=secret

# При локальном запуске без Docker замени DB_HOST на 127.0.0.1

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Внешние API — получи у владельца проекта
ASTROLOGY_API_KEY=
ANTHROPIC_API_KEY=
